# OpenAI (optional: the app retains demo fallbacks without this)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6
OPENAI_REALTIME_MODEL=gpt-realtime-2.1

# App
COOKIE_SECURE=false
ENOUGH_DB_PATH=enough.db
APP_BASE_URL=http://localhost:8770

# Scheduled delivery
ENABLE_NOTIFICATION_SCHEDULER=false
NOTIFICATION_POLL_SECONDS=30
SCHEDULER_SECRET=

# Browser / mobile PWA push
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com

# Email via Resend
RESEND_API_KEY=
EMAIL_FROM=Enough <notes@your-verified-domain.example>
UNSUBSCRIBE_SECRET=

# Optional per-companion Realtime voice overrides
OPENAI_REALTIME_VOICE_ROWAN=cedar
OPENAI_REALTIME_VOICE_MIRA=coral
OPENAI_REALTIME_VOICE_ELIAS=echo
OPENAI_REALTIME_VOICE_ANAYA=marin
OPENAI_REALTIME_VOICE_SOREN=sage